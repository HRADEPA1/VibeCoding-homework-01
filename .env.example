# ============================================================
#  Activity Recommender – environment configuration
#  Rename this file to .env and fill in the values you need.
#  The .env file is listed in .gitignore and will NOT be
#  committed to the repository.
# ============================================================

# ------------------------------------------------------------
# OPTION A: Remote OpenAI API  (requires a paid/free-trial account)
# Get your key at https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...your-key-here...

# Model to use (default: gpt-4o-mini).
# Other remote options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# MODEL_NAME=gpt-4o-mini

# ------------------------------------------------------------
# OPTION B: Local AI server – no API key needed
# Comment out OPENAI_API_KEY above and uncomment ONE of the
# sections below that matches your local setup.
# ------------------------------------------------------------

# -- Ollama (https://ollama.com) --
# 1. Install Ollama from https://ollama.com/download
# 2. Pull a model that supports tool calling, e.g.:
#      ollama pull llama3.1
#      ollama pull mistral-nemo
#      ollama pull qwen2.5
# 3. Ollama starts automatically; no extra command needed.
# OPENAI_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3.1

# -- LM Studio (https://lmstudio.ai) --
# 1. Install LM Studio from https://lmstudio.ai
# 2. Download a model inside LM Studio (e.g. Mistral-7B-Instruct).
# 3. Go to "Local Server" tab and click "Start Server".
# OPENAI_BASE_URL=http://localhost:1234/v1
# MODEL_NAME=mistral-7b-instruct
